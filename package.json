{
  "scripts": {
    "postinstall": "playwright install --with-deps",
    "lint:fix": "npx prettier --write .",
    "test:localhost": "ENVIRONMENT=localhost NODE_TLS_REJECT_UNAUTHORIZED=0 playwright test --update-snapshots --ui --grep-invert \"@service:wordpress @requires:aws\"",
    "test:develop": "ENVIRONMENT=develop playwright test --ui --grep-invert \"@wip\"",
    "test:staging": "ENVIRONMENT=staging playwright test --ui --grep-invert \"@wip\"",
    "test:production": "ENVIRONMENT=production playwright test --ui --grep-invert \"@wip\""
  },
  "dependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@estruyf/github-actions-reporter": "^1.9.2",
    "@playwright/test": "^1.59.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.2.3",
    "html-validate": "^10.1.1"
  }
}
